# Configuration must remain environment-based per infrastructure doctrine.
# Do not commit real secrets.

# Discord
DISCORD_APPLICATION_ID=replace_me
DISCORD_GUILD_ID=replace_me
DISCORD_PUBLIC_KEY=replace_me

# GuildBot
GUILDBOT_TOKEN=replace_me
GUILDBOT_LOG_LEVEL=info

# Custody API
CUSTODY_API_PORT=replace_me
CUSTODY_API_BASE_URL=replace_me

# Custody Portal
CUSTODY_PORTAL_PORT=replace_me
CUSTODY_PORTAL_BASE_URL=replace_me

# Postgres
POSTGRES_HOST=replace_me
POSTGRES_PORT=5432
POSTGRES_DB=replace_me
POSTGRES_USER=replace_me
POSTGRES_PASSWORD=replace_me

# Crypto Core
CRYPTO_CORE_CANONICAL_VERSION=v1
CRYPTO_CORE_SIGNING_DOMAIN=replace_me
